         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", "filename"}], "}"}], 
        "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"f", ",", 
       RowBox[{"doCodeEmission", "[", "arg", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Close", "[", "f", "]"}], ";"}]}], "\[IndentingNewLine]", 
