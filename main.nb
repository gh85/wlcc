             RowBox[{"--", 
              RowBox[{"--", 
               RowBox[{"--", 
                RowBox[{"--", 
                 RowBox[{"--", "-"}]}]}]}]}]}]}]}]}], "*)"}], 
        "\[IndentingNewLine]", 
        RowBox[{"asm", "=", 
         RowBox[{"asm", "<>", "\"\<\\tmov rax, \>\"", "<>", 
          RowBox[{"expectNumber", "[", "self", "]"}], "<>", "\"\<\\n\>\""}]}],
         ";", "\[IndentingNewLine]", 
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{"Not", "[", 
           RowBox[{"ateof", "[", "self", "]"}], "]"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
