Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"Main", "[", 
   RowBox[{"arg_", ",", "filename_"}], "]"}], ":=", 
  RowBox[{"Block", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"doCodeEmission", ",", "f"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"doCodeEmission", "[", "n_", "]"}], ":=", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", "asm", "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"asm", "=", "\"\<\>\""}], ";", "\[IndentingNewLine]", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<.intel_syntax noprefix\\n\>\""}]}], ";", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<.globl main\\n\>\""}]}], ";", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<main:\\n\>\""}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<\\tmov rax, \>\"", "<>", 
           RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<\\n\>\""}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<\\tret\\n\>\""}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "asm", "]"}]}]}], "\[IndentingNewLine]", 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"f", "=", 
      RowBox[{"OpenWrite", "[", 
       RowBox[{"FileNameJoin", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"NotebookDirectory", "[", "]"}], ",", "filename"}], "}"}], 
        "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"WriteString", "[", 
      RowBox[{"f", ",", 
       RowBox[{"doCodeEmission", "[", "arg", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Close", "[", "f", "]"}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]], "Input",
