   RowBox[{
    RowBox[{"{", 
     RowBox[{"doCodeEmission", ",", "f"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"doCodeEmission", "[", "n_", "]"}], ":=", 
      RowBox[{"Block", "[", 
       RowBox[{
        RowBox[{"{", "asm", "}"}], ",", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"asm", "=", "\"\<\>\""}], ";", "\[IndentingNewLine]", 
         RowBox[{"asm", "=", 
