     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"compileASM", "=", 
      RowBox[{"RunProcess", "[", 
       RowBox[{"{", "\[IndentingNewLine]", 
        RowBox[{"\"\<gcc\>\"", ",", "\[IndentingNewLine]", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"NotebookDirectory", "[", "]"}], ",", 
            RowBox[{"filename", "<>", "\"\<.s\>\""}]}], "}"}], "]"}], ",", 
         "\[IndentingNewLine]", "\"\<-o\>\"", ",", 
         RowBox[{"FileNameJoin", "[", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"NotebookDirectory", "[", "]"}], ",", "filename"}], "}"}],
           "]"}]}], "\[IndentingNewLine]", "}"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
