         "\[IndentingNewLine]", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<\\tmov rax, \>\"", "<>", 
           RowBox[{"ToString", "[", "n", "]"}], "<>", "\"\<\\n\>\""}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"asm", "=", 
          RowBox[{"asm", "<>", "\"\<\\tret\\n\>\""}]}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"Return", "[", "asm", "]"}]}]}], "\[IndentingNewLine]", 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"f", "=", 
      RowBox[{"OpenWrite", "[", 
