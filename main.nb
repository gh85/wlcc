        "\[IndentingNewLine]", 
        RowBox[{"TokenizerTokenize", "[", "tok", "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"self", "=", 
         RowBox[{"Parser", "[", 
          RowBox[{"tok", "[", "\"\<Tokens\>\"", "]"}], "]"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"asm", "=", "\"\<\>\""}], ";", "\[IndentingNewLine]", 
        RowBox[{"asm", "=", 
         RowBox[{"asm", "<>", "\"\<.intel_syntax noprefix\\n\>\""}]}], ";", 
        RowBox[{"asm", "=", 
         RowBox[{"asm", "<>", "\"\<.globl main\\n\>\""}]}], ";", 
        RowBox[{"asm", "=", 
         RowBox[{"asm", "<>", "\"\<main:\\n\>\""}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", 
